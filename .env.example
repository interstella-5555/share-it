# Copy to .env and fill in. All values shown are defaults (except ADMIN_KEY).

# HTTP listen port
PORT=3847

# Public base URL — used to build the `url` field in upload responses.
# Defaults to http://localhost:${PORT} when unset. Set to your public URL in prod.
# BASE_URL=https://share.example.com

# Upload size limit in MB. 413 if exceeded.
MAX_FILE_SIZE_MB=10

# Data directory. SQLite at ${DATA_DIR}/db.sqlite, blobs under ${DATA_DIR}/files.
DATA_DIR=./data

# Protected mode: when 'true', only pre-registered active keys can upload.
# When 'false', unknown keys are auto-registered as active on first upload.
PROTECTED_MODE=true

# Master key for admin endpoints (X-Admin-Key header).
# REQUIRED when PROTECTED_MODE=true. When unset, /admin/* returns 404.
# Generate with: uuidgen | tr '[:upper:]' '[:lower:]'
ADMIN_KEY=
